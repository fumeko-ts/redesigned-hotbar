{
  //i did a decent amount of debugging for a wile and could not figure out why the cooldown renderer wasent working so
  //its just not going to be in this pack for now if i can think of a way i will try to add it
  "hotbar_chooser": {
    "type": "panel",
    "size": [184, 26],
    "controls": [
      {
        "custom_hotbar": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": [184, 26],
          "offset": [-4, 1],
          "anchor_from": "bottom_middle",
          "anchor_to": "bottom_middle",
          "collection_name": "$hotbar_collection_name",
          "$hotbar_collection_name|default": "hotbar_items",
          "$extra_content|default": "common.empty_panel",
          "$is_end_cap|default": false,
          "controls": [
            {
              "start_cap@custom_hotbars.section_template": {
                "uv": [0, 0],
                "$is_end_cap": true,
                "uv_size": [2, 26],
                "size": [2, 26]
              }
            },
            {
              "0@custom_hotbars.section_0": {
                "$extra_content": "hud.custom_inventory_button_left",
                "collection_index": 0
              }
            },
            { "1@custom_hotbars.section_1": { "collection_index": 1 } },
            { "2@custom_hotbars.section_2": { "collection_index": 2 } },
            { "3@custom_hotbars.section_3": { "collection_index": 3 } },
            { "4@custom_hotbars.section_4": { "collection_index": 4 } },
            { "5@custom_hotbars.section_5": { "collection_index": 5 } },
            { "6@custom_hotbars.section_6": { "collection_index": 6 } },
            { "7@custom_hotbars.section_7": { "collection_index": 7 } },
            {
              "8@custom_hotbars.section_8": {
                "$extra_content": "hud.custom_inventory_button_right",
                "collection_index": 8
              }
            },
            {
              "end_cap@custom_hotbars.section_template": {
                "uv": [182, 0],
                "$is_end_cap": true,
                "uv_size": [2, 26],
                "size": [2, 26]
              }
            }
          ]
        }
      }
    ]
  },
  "custom_inventory_button_left@custom_hotbars.inventory_button": {
    "offset": [-5, 0],
    "anchor_from": "left_middle",
    "anchor_to": "right_middle",
    "bindings": [
      {
        "binding_name": "#hotbar_elipses_left_visible",
        "binding_name_override": "#visible",
        "binding_type": "global"
      }
    ]
  },
  "custom_inventory_button_right@custom_hotbars.inventory_button": {
    "offset": [5, 0],
    "anchor_from": "right_middle",
    "anchor_to": "left_middle",
    "bindings": [
      {
        "binding_name": "#hotbar_elipses_right_visible",
        "binding_name_override": "#visible",
        "binding_type": "global"
      }
    ]
  },
  //ngl no clue what the below actualy offsets but seems to work for me so im just going to roll with it
  //if eanyone knows a better way feel free to inform me i would love to know
  "root_panel/exp_rend_resizable": { "offset": [0, -17] },
  "root_panel/exp_rend": { "offset": [0, -17] },
  "root_panel/centered_gui_elements_at_bottom_middle": { "offset": [0, -3] }
}
